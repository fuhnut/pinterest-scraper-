{
  "manifest_version": 3,
  "name": "psx scrape",
  "version": "3.0",
  "description": "Fast Pinterest scraper with multi-tab support, pause/resume, overlay UI, and background worker.",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["https://*.pinterest.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["overlay.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
